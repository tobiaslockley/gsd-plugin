{
  "description": "GSD workflow hooks -- session context loading, workflow enforcement, and tool-use monitoring",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/bin/gsd-tools.cjs\" hook session-start",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/bin/gsd-tools.cjs\" hook pre-tool-use",
            "timeout": 3000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/bin/gsd-tools.cjs\" hook post-tool-use",
            "timeout": 3000
          }
        ]
      }
    ]
  }
}
